# =============================================================================
# Multitenant Template — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in real values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# Variables WITHOUT that prefix are server-only — never expose them client-side.
# =============================================================================

# ---- Supabase ---------------------------------------------------------------
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# For local dev with `npx supabase start`, use the values printed by that command.

NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<your-anon-or-publishable-key>"

# Server-only. Bypasses RLS. Use ONLY in lib/supabase/service.ts.
# Required for: custom_access_token_hook admin work, switch-workspace endpoint,
# user invitation flows, and any background job that needs full DB access.
SUPABASE_SERVICE_ROLE_KEY="<your-service-role-key>"

# ---- Tenancy ----------------------------------------------------------------
# The root domain of your platform (no protocol). Used to:
#   - Strip from the Host header to extract the company subdomain.
#   - Build absolute redirects in the auth callback.
# Local dev example: tuapp.local (add `127.0.0.1 acme.tuapp.local` to /etc/hosts)
# Production example: tuapp.com

NEXT_PUBLIC_ROOT_DOMAIN="tuapp.local"

# Optional: scheme override. Defaults to https. Set to http for local dev if
# your local Supabase Studio is on plain http.
NEXT_PUBLIC_APP_SCHEME="http"

# ---- Setup script (only needed when running scripts/setup-supabase.ts) -----
# Your Supabase project ID (the abcdefghij from
# https://supabase.com/dashboard/project/abcdefghij).
# Used by: pnpm setup:supabase* scripts to target a real remote project.
SUPABASE_PROJECT_REF=""

# A Personal Access Token from https://supabase.com/dashboard/account/tokens.
# This is NOT the same as the service role key. Used only by setup scripts.
# Treat as a secret. Required scope: "project:write" at minimum.
SUPABASE_ACCESS_TOKEN=""

# ---- Vercel (only needed when running scripts/vercel-cli.ts or CI) --------
# A Personal Access Token from https://vercel.com/account/tokens.
# Scope: "Full Access" gives the agent control over deploys, env vars, domains,
# logs, and project settings. Use "Limited Access" tokens for tighter blast radius.
# Treat as a secret. If leaked, revoke from the same page and reissue.
VERCEL_TOKEN=""

# Your Vercel team/org ID. From the URL when you're in the dashboard:
#   https://vercel.com/<TEAM_SLUG>/~/projects -> team_<id> at the bottom of
#   the project settings, or run `vercel whoami` after `vercel login`.
VERCEL_ORG_ID=""

# Your Vercel project ID (or slug — both work). Visible in the URL when
# you're in the project dashboard. Set automatically by `vercel link` if
# you skip it; but specifying it removes ambiguity.
VERCEL_PROJECT_ID=""